{
  "build": {
    "beforeDevCommand": "yarn dev --host",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "longDescription": "tymt is a multi-chain game launcher and an environment for creating and publishing games. \n tymt is a gaming environment and platform, built using the Solar Core blockchain solutions, enabling a new world of game economy - empowering Developers and Publishers!",
    "publisher": "hello@solarenterprises.com",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "category": "Game",
    "shortDescription": "A multi-chain game launcher and an environment for creating and publishing games",
    "createUpdaterArtifacts": true
  },
  "productName": "tymtLauncher",
  "mainBinaryName": "tymtLauncher",
  "version": "2.2.2",
  "identifier": "tymtLauncher",
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI3M0I1Mzc1RUM4NDAxMDQKUldRRUFZVHNkVk03SnhrVnRrbDJKYnpnTWFTZEYvSHJZejZNcHJyd1h2SngwMGR0b1BOek9vTUIK",
      "endpoints": ["https://github.com/solarenterprises/tymt-launcher-client-tauri/releases/latest/download/latest.json"]
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "tymtLauncher",
        "title": "tymtLauncher",
        "resizable": true,
        "width": 1440,
        "height": 800,
        "minWidth": 1200,
        "minHeight": 800,
        "center": true,
        "dragDropEnabled": false
      },
      {
        "label": "tymt_d53_transaction",
        "title": "D53 transaction",
        "url": "d53-transaction",
        "transparent": true,
        "decorations": false,
        "resizable": false,
        "visible": false,
        "width": 440,
        "x": 5,
        "y": 5,
        "alwaysOnTop": true,
        "focus": true
      },
      {
        "label": "game_window",
        "title": "Game Window",
        "url": "",
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'unsafe-eval'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: https:",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost https://*.tymt.com https://api.solar.org wss://metamask-sdk.api.cx.metamask.io https://metamask-sdk.api.cx.metamask.io https://*.valist.io https://*.veloren.net https://*.github.com https://*.epicgames.com https://*.aka.ms",
        "media-src": "'self' https://*.tymt.com https://*.railway.app",
        "frame-src": "'none' https://www.youtube.com https://www.youtube-nocookie.com",
        "object-src": "'none'",
        "base-uri": "'self'"
      },
      "dangerousDisableAssetCspModification": false,
      "capabilities": ["main-capability"]
    },
    "macOSPrivateApi": true
  }
}
